{
  "version": 2,
  "builds": [
    { "src": "dsport-voice/api/chat.js", "use": "@vercel/node" },
    { "src": "dsport-voice/api/tts.js", "use": "@vercel/node" },
    { "src": "dsport-voice/api/voice.js", "use": "@vercel/node" },
    { "src": "dsport-voice/api/realtime.js", "use": "@vercel/node" },
    { "src": "dsport-voice/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/dsport-voice/api/chat.js" },
    { "src": "/api/tts", "dest": "/dsport-voice/api/tts.js" },
    { "src": "/api/voice", "dest": "/dsport-voice/api/voice.js" },
    { "src": "/api/realtime", "dest": "/dsport-voice/api/realtime.js" },
    { "src": "/(.*)", "dest": "/dsport-voice/index.html" }
  ]
}
